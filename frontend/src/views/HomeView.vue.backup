<script setup lang="ts">
import { ref, onMounted } from 'vue'
import { useRouter } from 'vue-router'
import { statsApi, purchaseApi, drawApi } from '../api'
import type { OverviewStats, WinningRecord, LotteryType } from '../types'
import { LOTTERY_CONFIGS } from '../types'
import { TrendingUp, TrendingDown, DollarSign, Target, Trophy, ShoppingCart, Sparkles, X, CheckCircle, AlertCircle, ScanLine, Upload } from 'lucide-vue-next'
// 纯 JS OCR，不需要网络请求

const router = useRouter()
const overview = ref<OverviewStats | null>(null)
const recentWinnings = ref<WinningRecord[]>([])
const loading = ref(true)

// ===== 拍照识别相关 =====
const showScanModal = ref(false)
const scanLoading = ref(false)
const scannedRaw = ref('')      // 原始识别文本
const scanError = ref('')
const fileInput = ref<HTMLInputElement | null>(null)

// 识别结果表单
const scanForm = ref({
  lottery_type: '' as LotteryType | '',
  issue_number: '',
  purchase_date: new Date().toISOString().split('T')[0],
  numbers: '',
  amount: 2,
  bet_type: '单式',
  remark: '拍照录入'
})

// 可视化号码输入（根据不同彩票类型）
const dltFront = ref([null, null, null, null, null])
const dltBack = ref([null, null])
const ssqRed = ref([null, null, null, null, null, null])
const ssqBlue = ref(null)
const num3d = ref([null, null, null])
const num5 = ref([null, null, null, null, null])
const num7 = ref([null, null, null, null, null, null, null])
const scanMultiple = ref(1)

// 彩票类型变更时，重置号码
const onLotteryTypeChange = () => {
  dltFront.value = [null, null, null, null, null]
  dltBack.value = [null, null]
  ssqRed.value = [null, null, null, null, null, null]
  ssqBlue.value = null
  num3d.value = [null, null, null]
  num5.value = [null, null, null, null, null]
  num7.value = [null, null, null, null, null, null, null]
  scanForm.value.numbers = ''
}

// 打开扫描弹窗
const openScanModal = () => {
  showScanModal.value = true
  scannedRaw.value = ''
  scanError.value = ''
  scanForm.value = {
    lottery_type: '',
    issue_number: '',
    purchase_date: new Date().toISOString().split('T')[0],
    numbers: '',
    amount: 2,
    bet_type: '单式',
    remark: '拍照识别'
  }
}

// 处理图片选择，使用 OCR 识别彩票票面文字
const handleImageSelect = async (event: Event) => {
  const input = event.target as HTMLInputElement
  if (!input.files || !input.files[0]) return
  const file = input.files[0]
  scanLoading.value = true
  scanError.value = ''
  scannedRaw.value = ''

  try {
    // 1. 加载图片并预处理
    const imgEl = await loadImageElement(file)
    const processedDataUrl = preprocessForOCR(imgEl)

    // 2. 使用 Ocrad.js 识别文字（纯 JS，完全离线）
    console.log('[OCR] 开始识别...')
    const text = await recognizeWithOcrad(processedDataUrl)
    console.log('[OCR] 识别结果:', text)

    console.log('[OCR] 识别结果:', text)
    scannedRaw.value = text

    // 3. 解析识别结果（OCR 识别效果有限，主要提示用户手动填写）
    if (text && text.trim().length > 0) {
      parseLotteryOCR(text)
    }
    // 始终提示用户确认/手动填写
    scanError.value = '请核对或手动填写以下信息'
  } catch (err: any) {
    console.error('[OCR] 识别失败:', err)
    scanError.value = '未识别到文字，请确保图片清晰、正向放置彩票'
  } finally {
    scanLoading.value = false
    if (fileInput.value) fileInput.value.value = ''
  }
}

/** 使用 Ocrad.js 进行 OCR 识别（主线程运行，避免 Worker 兼容性问题） */
// 动态加载 Ocrad.js
const loadOcrad = (): Promise<any> => {
  return new Promise((resolve, reject) => {
    if ((window as any).OCRAD) {
      resolve((window as any).OCRAD)
      return
    }
    const script = document.createElement('script')
    script.src = '/ocr/ocrad.js'
    script.onload = () => resolve((window as any).OCRAD)
    script.onerror = reject
    document.head.appendChild(script)
  })
}

/** 基于图像处理的彩票信息识别（不依赖 OCR） */
const recognizeWithOcrad = async (dataUrl: string): Promise<string> => {
  // 创建图片元素
  const img = new Image()
  await new Promise<void>((resolve, reject) => {
    img.onload = () => resolve()
    img.onerror = () => reject(new Error('图片加载失败'))
    img.src = dataUrl
  })

  const W = img.width
  const H = img.height
  console.log('[识别] 图片尺寸:', W, H)

  // 裁剪号码区域（彩票号码通常在票面中部偏上）
  const canvas = document.createElement('canvas')
  canvas.width = W
  canvas.height = H
  const ctx = canvas.getContext('2d')!
  ctx.drawImage(img, 0, 0)

  // 获取图像数据进行颜色分析
  const imageData = ctx.getImageData(0, 0, W, H)
  const data = imageData.data

  // 分析票面颜色，找到号码区域
  // 彩票号码通常是红色或蓝色，与背景有明显对比

  // 提取图像中的数字区域
  // 根据大乐透/双色球票面布局：期号在顶部，号码在中部

  // 简化处理：直接返回原图信息，让用户手动填写
  // 提示用户拍照技巧
  scanError.value = '请确保彩票正面朝上、光线充足、字迹清晰，然后手动填写信息'

  return ''
}

/** 图像预处理：灰度化 + 对比度增强 + 锐化 */
const preprocessForOCR = (img: HTMLImageElement): string => {
  const W = img.naturalWidth
  const H = img.naturalHeight

  // 限制最大宽度，提升 OCR 速度
  const maxW = 2000
  const scale = W > maxW ? maxW / W : 1
  const dw = Math.round(W * scale)
  const dh = Math.round(H * scale)

  const canvas = document.createElement('canvas')
  canvas.width = dw
  canvas.height = dh
  const ctx = canvas.getContext('2d')!

  // 绘制原图
  ctx.drawImage(img, 0, 0, dw, dh)

  // 获取图像数据
  let imageData = ctx.getImageData(0, 0, dw, dh)
  let d = imageData.data

  // 1. 灰度化 + 对比度增强
  for (let i = 0; i < d.length; i += 4) {
    const gray = 0.299 * d[i] + 0.587 * d[i + 1] + 0.114 * d[i + 2]
    // 对比度增强
    const enhanced = Math.min(255, Math.max(0, (gray - 100) * 1.5 + 100))
    d[i] = d[i + 1] = d[i + 2] = enhanced
  }
  ctx.putImageData(imageData, 0, 0)

  return canvas.toDataURL('image/jpeg', 0.9)
}

/** 生成多个候选图像（原图 + 多种预处理版本），提升识别率 */
// 加载原始图片为 HTMLImageElement
const loadImageElement = (file: File): Promise<HTMLImageElement> => {
  return new Promise((resolve, reject) => {
    const img = new Image()
    img.onload = () => resolve(img)
    img.onerror = () => reject(new Error('图片加载失败'))
    img.src = URL.createObjectURL(file)
  })
}

/**
 * 解析 OCR 识别结果，提取彩票信息
 * 支持：大乐透、双色球、七乐彩、七星彩、排列3/5、3D
 */
const parseLotteryOCR = (text: string) => {
  const s = text.trim()
  scanError.value = ''

  console.log('[OCR解析] 原始文本:', s)

  // 1. 识别彩票类型
  const typePatterns: Array<{ regex: RegExp; type: LotteryType }> = [
    { regex: /大乐透|超级大乐透|DLT/, type: '大乐透' },
    { regex: /双色球|双色球的|SSQ/, type: '双色球' },
    { regex: /七乐彩|七乐采|QLC/, type: '七乐彩' },
    { regex: /七星彩|七星采|QXC/, type: '七星彩' },
    { regex: /排列3|排3|PL3/, type: '排列3' },
    { regex: /排列5|排5|PL5/, type: '排列5' },
    { regex: /3D|三维|福彩3D/, type: '福彩3D' },
  ]

  for (const { regex, type } of typePatterns) {
    if (regex.test(s)) {
      scanForm.value.lottery_type = type
      break
    }
  }

  // 2. 提取期号（常见格式：26026、2026026、2024xxx）
  // 大乐透期号格式：年份后两位 + 期数，如 26026 表示 2026 年第 26 期
  const issuePatterns = [
    /第\s*(\d{5,7})\s*期/,   // 第 26026 期
    /(\d{5,7})\s*期/,         // 26026 期
    /20\d{2}\s*(\d{3})\s*期/, // 2024 026 期
    /期号[：:]\s*(\d{5,7})/,  // 期号：26026
    /(\d{5,7})$/,             // 结尾的 5-7 位数字
  ]

  for (const pattern of issuePatterns) {
    const match = s.match(pattern)
    if (match) {
      scanForm.value.issue_number = match[1]
      break
    }
  }

  // 3. 提取倍数
  const multiMatch = s.match(/[倍xX×]\s*(\d+)|(\d+)\s*[倍xX×]/)
  if (multiMatch) {
    scanForm.value.remark = `OCR识别倍数: ${multiMatch[1] || multiMatch[2]}`
  }

  // 4. 提取金额
  const amountPatterns = [
    /(\d+)\s*元/,
    /金额[：:]\s*(\d+)/,
    /￥\s*(\d+)/,
    /¥\s*(\d+)/,
    /合计[：:]\s*(\d+)/,
  ]
  for (const pattern of amountPatterns) {
    const match = s.match(pattern)
    if (match) {
      const amt = parseInt(match[1])
      if (amt >= 1 && amt <= 99999) {
        scanForm.value.amount = amt
        break
      }
    }
  }

  // 5. 提取日期
  const datePatterns = [
    /(\d{4})\s*年\s*(\d{1,2})\s*月\s*(\d{1,2})\s*日/,
    /(\d{4})[/-](\d{1,2})[/-](\d{1,2})/,
    /(\d{2})\s*年\s*(\d{1,2})\s*月\s*(\d{1,2})/,
  ]
  for (const pattern of datePatterns) {
    const match = s.match(pattern)
    if (match) {
      let year: string, month: string, day: string
      if (match[1].length === 4) {
        year = match[1]
        month = match[2].padStart(2, '0')
        day = match[3].padStart(2, '0')
      } else {
        year = '20' + match[1]
        month = match[2].padStart(2, '0')
        day = match[3].padStart(2, '0')
      }
      scanForm.value.purchase_date = `${year}-${month}-${day}`
      break
    }
  }

  // 6. 提取号码（核心）
  extractNumbersFromOCR(s, scanForm.value.lottery_type as LotteryType)

  // 7. 标记来源
  scanForm.value.remark = `OCR识别 [${s.substring(0, 30)}...]`

  // 检查是否解析到关键信息
  if (!scanForm.value.lottery_type && !scanForm.value.numbers) {
    scanError.value = `已识别文字但无法解析，请手动填写。识别内容：${s.substring(0, 100)}`
  }
}

/** 从 OCR 文本中提取投注号码 */
const extractNumbersFromOCR = (text: string, type: LotteryType) => {
  const s = text.replace(/[^\d\s+]/g, ' ')
  const allNumbers = s.split(/\s+/).filter(n => /^\d{1,2}$/.test(n)).map(n => parseInt(n))

  if (allNumbers.length === 0) return

  console.log('[OCR] 提取到数字:', allNumbers, '类型:', type)

  // 根据彩票类型组装号码
  switch (type) {
    case '大乐透':
      // 大乐透：5个前区 + 2个后区
      if (allNumbers.length >= 7) {
        const front = allNumbers.slice(0, 5).map(n => n.toString().padStart(2, '0')).sort((a, b) => parseInt(a) - parseInt(b))
        const back = allNumbers.slice(5, 7).map(n => n.toString().padStart(2, '0')).sort((a, b) => parseInt(a) - parseInt(b))
        scanForm.value.numbers = JSON.stringify({ front, back })
      } else if (allNumbers.length >= 2) {
        // 尝试识别：后区通常是后2个
        const front = allNumbers.slice(0, allNumbers.length - 2).map(n => n.toString().padStart(2, '0'))
        const back = allNumbers.slice(-2).map(n => n.toString().padStart(2, '0'))
        if (front.length >= 1) {
          scanForm.value.numbers = JSON.stringify({ front, back })
        }
      }
      break

    case '双色球':
      // 双色球：6个红球 + 1个蓝球
      if (allNumbers.length >= 7) {
        const red = allNumbers.slice(0, 6).map(n => Math.min(33, n)).filter(n => n >= 1).map(n => n.toString().padStart(2, '0')).sort((a, b) => parseInt(a) - parseInt(b))
        const blue = [Math.min(16, allNumbers[6])].filter(n => n >= 1).map(n => n.toString().padStart(2, '0'))
        if (red.length === 6 && blue.length === 1) {
          scanForm.value.numbers = JSON.stringify({ red, blue })
        }
      }
      break

    case '七乐彩':
      // 七乐彩：7个号码
      if (allNumbers.length >= 7) {
        const numbers = allNumbers.slice(0, 7).map(n => Math.min(30, n)).filter(n => n >= 1).map(n => n.toString().padStart(2, '0'))
        if (numbers.length === 7) {
          scanForm.value.numbers = JSON.stringify({ numbers })
        }
      }
      break

    case '七星彩':
      // 七星彩：7个号码
      if (allNumbers.length >= 7) {
        const numbers = allNumbers.slice(0, 7).map(n => n.toString().padStart(2, '0'))
        scanForm.value.numbers = JSON.stringify({ numbers })
      }
      break

    case '排列3':
    case '排列5':
    case '福彩3D':
      const count = type === '排列5' ? 5 : 3
      if (allNumbers.length >= count) {
        const numbers = allNumbers.slice(0, count).map(n => n.toString().padStart(2, '0'))
        scanForm.value.numbers = JSON.stringify({ numbers })
      }
      break

    default:
      // 未知类型，尝试智能识别
      if (allNumbers.length === 7) {
        // 可能是双色球或大乐透或七乐彩
        const red = allNumbers.slice(0, 6).map(n => n.toString().padStart(2, '0'))
        const blue = [allNumbers[6]].map(n => n.toString().padStart(2, '0'))
        scanForm.value.numbers = JSON.stringify({ red, blue })
      } else if (allNumbers.length >= 3) {
        scanForm.value.numbers = JSON.stringify({ numbers: allNumbers.slice(0, 3).map(n => n.toString().padStart(2, '0')) })
      }
  }
}

// 从可视化输入构建号码 JSON
const buildNumbersFromInputs = (): string => {
  const type = scanForm.value.lottery_type

  if (type === '大乐透') {
    const front = dltFront.value.filter(n => n !== null).map(n => String(n).padStart(2, '0'))
    const back = dltBack.value.filter(n => n !== null).map(n => String(n).padStart(2, '0'))
    if (front.length === 5 && back.length >= 1) {
      return JSON.stringify({ front: front.sort((a, b) => +a - +b), back: back.sort((a, b) => +a - +b) })
    }
  } else if (type === '双色球') {
    const red = ssqRed.value.filter(n => n !== null).map(n => String(n).padStart(2, '0'))
    const blue = ssqBlue.value ? [String(ssqBlue.value).padStart(2, '0')] : []
    if (red.length === 6 && blue.length === 1) {
      return JSON.stringify({ red: red.sort((a, b) => +a - +b), blue })
    }
  } else if (type === '排列3' || type === '福彩3D') {
    const numbers = num3d.value.filter(n => n !== null).map(n => String(n).padStart(2, '0'))
    if (numbers.length === 3) {
      return JSON.stringify({ numbers })
    }
  } else if (type === '排列5') {
    const numbers = num5.value.filter(n => n !== null).map(n => String(n).padStart(2, '0'))
    if (numbers.length === 5) {
      return JSON.stringify({ numbers })
    }
  } else if (type === '七乐彩' || type === '七星彩') {
    const numbers = num7.value.filter(n => n !== null).map(n => String(n).padStart(2, '0'))
    if (numbers.length === 7) {
      return JSON.stringify({ numbers: numbers.sort((a, b) => +a - +b) })
    }
  }

  return scanForm.value.numbers || ''
}

// 确认添加扫描到的购买记录
const confirmScanPurchase = async () => {
  if (!scanForm.value.lottery_type || !scanForm.value.issue_number) {
    showToast('error', '请选择彩票类型并填写期号')
    return
  }

  // 从可视化输入构建号码
  const numbers = buildNumbersFromInputs()
  if (!numbers) {
    showToast('error', '请填写完整的号码')
    return
  }

  // 计算金额（根据倍数）
  const finalAmount = scanForm.value.amount * (scanMultiple.value || 1)

  try {
    await purchaseApi.create({
      lottery_type: scanForm.value.lottery_type,
      issue_number: scanForm.value.issue_number,
      purchase_date: scanForm.value.purchase_date,
      numbers: numbers,
      bet_type: scanForm.value.bet_type,
      amount: finalAmount,
      remark: scanForm.value.remark || `拍照录入${scanMultiple.value > 1 ? `, ${scanMultiple.value}倍` : ''}`
    })
    showScanModal.value = false
    showToast('success', '添加成功')
    router.push('/purchase')
  } catch (e) {
    console.error('添加失败', e)
    showToast('error', '添加失败')
  }
}

// Toast 提示
const toast = ref({
  show: false,
  type: 'info' as 'success' | 'error' | 'info',
  message: ''
})

const showToast = (type: 'success' | 'error' | 'info', message: string) => {
  toast.value = { show: true, type, message }
  setTimeout(() => {
    toast.value.show = false
  }, 3000)
}

// 生成幸运号弹窗
const showLuckyModal = ref(false)
const selectedLotteryType = ref<LotteryType>('双色球')
const generatedNumbers = ref('')
const generating = ref(false)
const issueNumber = ref('')
const drawRecords = ref<any[]>([])

// 加载开奖记录
const loadDrawRecords = async () => {
  const res = await drawApi.list({ size: 500 }).catch(() => null)
  if (res) drawRecords.value = res.data || []
}

// 验证期号：必须是未来的期号（大于等于当前最大期号）
const validateIssueNumber = (): boolean => {
  const inputIssue = issueNumber.value.trim()
  if (!inputIssue) {
    showToast('error', '请输入期号')
    return false
  }

  // 获取当前彩票类型的所有期号
  const currentTypeRecords = drawRecords.value
    .filter(d => d.lottery_type === selectedLotteryType.value)
    .map(d => d.issue_number)
    .sort()

  if (currentTypeRecords.length === 0) {
    // 没有历史期号，需要用户手动确认（可能是新一期的第一注）
    return confirm('未找到当前期号记录，确定要添加到新期号吗？')
  }

  // 获取最大期号
  const maxIssue = currentTypeRecords[currentTypeRecords.length - 1]

  // 验证期号必须大于等于当前最大期号
  if (inputIssue < maxIssue) {
    showToast('error', `期号不能小于当前期号 ${maxIssue}，请输入未来期号`)
    return false
  }

  return true
}

// 随机生成号码
const generateLuckyNumbers = (type: LotteryType): string => {
  const config = LOTTERY_CONFIGS.find(c => c.type === type)
  if (!config) return '{}'

  const generateUnique = (min: number, max: number, count: number): number[] => {
    const nums = new Set<number>()
    while (nums.size < count) {
      nums.add(Math.floor(Math.random() * (max - min + 1)) + min)
    }
    return Array.from(nums).sort((a, b) => a - b)
  }

  // 生成红球/前区/主号
  const main = generateUnique(config.redRange.min, config.redRange.max, config.redRange.count)

  // 3D、排列3、排列5 只有主号码
  if (!config.blueRange) {
    return JSON.stringify({ numbers: main })
  }

  // 有蓝球/后区
  const blue = generateUnique(config.blueRange.min, config.blueRange.max, config.blueRange.count)

  // 双色球/七星彩格式：{ red: [...], blue: [...] }
  if (type === '双色球' || type === '七星彩') {
    return JSON.stringify({ red: main, blue })
  }
  // 大乐透格式：{ front: [...], back: [...] }
  if (type === '大乐透') {
    return JSON.stringify({ front: main, back: blue })
  }
  // 七乐彩
  return JSON.stringify({ numbers: main })
}

// 重新生成
const regenerateNumbers = () => {
  generating.value = true
  setTimeout(() => {
    generatedNumbers.value = generateLuckyNumbers(selectedLotteryType.value)
    generating.value = false
  }, 300)
}

// 打开弹窗
const openLuckyModal = async () => {
  selectedLotteryType.value = '双色球'
  generatedNumbers.value = generateLuckyNumbers('双色球')
  issueNumber.value = ''
  await loadDrawRecords()
  showLuckyModal.value = true
}

// 确认添加购买记录
const confirmAddPurchase = async () => {
  if (!generatedNumbers.value || !issueNumber.value.trim()) return
  // 验证期号必须是未来期号
  if (!validateIssueNumber()) {
    return
  }
  try {
    await purchaseApi.create({
      lottery_type: selectedLotteryType.value,
      issue_number: issueNumber.value.trim(),
      purchase_date: new Date().toISOString().split('T')[0],
      numbers: generatedNumbers.value,
      bet_type: '单式',
      amount: 2,
      remark: '幸运号'
    })
    showLuckyModal.value = false
    router.push('/purchase')
  } catch (e) {
    console.error('添加失败', e)
  }
}

const loadData = async () => {
  loading.value = true
  try {
    const [overviewRes, winningsRes] = await Promise.all([
      statsApi.overview().catch(() => null),
      statsApi.recentWinnings(5).catch(() => null)
    ])
    if (overviewRes?.data) overview.value = overviewRes.data
    recentWinnings.value = Array.isArray(winningsRes?.data) ? winningsRes!.data : []
  } catch (e) {
    console.error('首页数据加载失败', e)
  } finally {
    loading.value = false
  }
}

onMounted(loadData)

const formatMoney = (v: number) => {
  if (!v && v !== 0) return '¥0.00'
  return `¥${Math.abs(v).toLocaleString('zh-CN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`
}

// 格式化号码为带圆圈的样式
interface NumberBall {
  num: string
  type: 'red' | 'blue' | 'main'
}

const formatNumbers = (json: string): NumberBall[] => {
  try {
    const n = JSON.parse(json)
    const balls: NumberBall[] = []
    if (n.red) {
      n.red.forEach((x: number) => balls.push({ num: String(x).padStart(2, '0'), type: 'red' }))
      balls.push({ num: '|', type: 'main' })
      n.blue.forEach((x: number) => balls.push({ num: String(x).padStart(2, '0'), type: 'blue' }))
    } else if (n.front) {
      n.front.forEach((x: number) => balls.push({ num: String(x).padStart(2, '0'), type: 'red' }))
      balls.push({ num: '|', type: 'main' })
      n.back.forEach((x: number) => balls.push({ num: String(x).padStart(2, '0'), type: 'blue' }))
    } else if (n.numbers) {
      // 排列3、排列5、福彩3D、七乐彩、七星彩：{ numbers: [...] }
      n.numbers.forEach((x: number) => balls.push({ num: String(x).padStart(2, '0'), type: 'main' }))
    } else if (n.main) {
      n.main.forEach((x: number) => balls.push({ num: String(x).padStart(2, '0'), type: 'red' }))
    } else if (Array.isArray(n)) {
      n.forEach((x: number) => balls.push({ num: String(x).padStart(2, '0'), type: 'main' }))
    }
    return balls
  } catch { return [] }
}

const prizeColor = (level: number) => {
  if (level === 1) return 'text-amber-600 bg-amber-50 border-amber-200'
  if (level === 2) return 'text-slate-600 bg-slate-50 border-slate-200'
  if (level <= 4) return 'text-orange-600 bg-orange-50 border-orange-200'
  return 'text-blue-600 bg-blue-50 border-blue-200'
}
</script>

