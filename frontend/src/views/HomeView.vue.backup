                  <span class="text-xs text-slate-500 w-12">号码(5个)</span>
                  <input v-model.number="num5[0]" type="number" min="0" max="9" placeholder="0" class="w-12 px-2 py-2 border rounded-lg text-center" />
                  <input v-model.number="num5[1]" type="number" min="0" max="9" placeholder="1" class="w-12 px-2 py-2 border rounded-lg text-center" />
                  <input v-model.number="num5[2]" type="number" min="0" max="9" placeholder="2" class="w-12 px-2 py-2 border rounded-lg text-center" />
                  <input v-model.number="num5[3]" type="number" min="0" max="9" placeholder="3" class="w-12 px-2 py-2 border rounded-lg text-center" />
                  <input v-model.number="num5[4]" type="number" min="0" max="9" placeholder="4" class="w-12 px-2 py-2 border rounded-lg text-center" />
                </div>
              </div>

              <!-- 七乐彩/七星彩：7个号码 -->
              <div v-else-if="scanForm.lottery_type === '七乐彩' || scanForm.lottery_type === '七星彩'" class="space-y-2">
                <div class="flex flex-wrap items-center gap-1">
                  <span class="text-xs text-slate-500 w-12">号码(7个)</span>
                  <input v-model.number="num7[0]" type="number" min="1" :max="scanForm.lottery_type === '七乐彩' ? 30 : 9" placeholder="1" class="w-10 px-1 py-2 border rounded-lg text-center" />
                  <input v-model.number="num7[1]" type="number" min="1" :max="scanForm.lottery_type === '七乐彩' ? 30 : 9" placeholder="2" class="w-10 px-1 py-2 border rounded-lg text-center" />
                  <input v-model.number="num7[2]" type="number" min="1" :max="scanForm.lottery_type === '七乐彩' ? 30 : 9" placeholder="3" class="w-10 px-1 py-2 border rounded-lg text-center" />
                  <input v-model.number="num7[3]" type="number" min="1" :max="scanForm.lottery_type === '七乐彩' ? 30 : 9" placeholder="4" class="w-10 px-1 py-2 border rounded-lg text-center" />
                  <input v-model.number="num7[4]" type="number" min="1" :max="scanForm.lottery_type === '七乐彩' ? 30 : 9" placeholder="5" class="w-10 px-1 py-2 border rounded-lg text-center" />
                  <input v-model.number="num7[5]" type="number" min="1" :max="scanForm.lottery_type === '七乐彩' ? 30 : 9" placeholder="6" class="w-10 px-1 py-2 border rounded-lg text-center" />
                  <input v-model.number="num7[6]" type="number" min="1" :max="scanForm.lottery_type === '七乐彩' ? 30 : 9" placeholder="7" class="w-10 px-1 py-2 border rounded-lg text-center" />
                </div>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-sm font-medium text-slate-600 mb-1.5">购买日期</label>
                <input
                  v-model="scanForm.purchase_date"
                  type="date"
                  class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:border-purple-400"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-600 mb-1.5">金额 (元)</label>
                <input
                  v-model.number="scanForm.amount"
                  type="number"
                  step="2"
                  min="0"
                  class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:border-purple-400"
                />
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-600 mb-1.5">倍数/注数</label>
              <div class="flex gap-2">
                <select
                  v-model="scanForm.bet_type"
                  class="flex-1 px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:border-purple-400 cursor-pointer"
                >
                  <option value="单式">单式</option>
                  <option value="复式">复式</option>
                  <option value="胆拖">胆拖</option>
                </select>
                <input
                  v-model.number="scanMultiple"
                  type="number"
                  min="1"
                  placeholder="倍数"
                  class="w-24 px-3 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:border-purple-400"
                />
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-600 mb-1.5">备注</label>
              <input
                v-model="scanForm.remark"
                type="text"
                placeholder="可选"
                class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:border-purple-400"
              />
            </div>
          </div>
        </div>

        <div class="border-t border-slate-100 px-6 py-4 flex gap-3">
          <button
            @click="showScanModal = false"
            class="flex-1 px-4 py-2.5 text-slate-600 hover:bg-slate-100 rounded-xl font-medium transition-colors cursor-pointer"
          >
            取消
          </button>
          <button
            @click="confirmScanPurchase"
            :disabled="scanLoading"
            class="flex-1 px-4 py-2.5 bg-purple-500 hover:bg-purple-600 text-white rounded-xl font-medium transition-colors cursor-pointer disabled:opacity-50"
          >
            添加到购买记录
          </button>
        </div>
      </div>
    </div>

    <!-- Toast 提示 -->
    <Transition>
      <div
        v-if="toast.show"
        class="fixed top-20 left-1/2 -translate-x-1/2 z-[100] px-6 py-3 rounded-xl shadow-lg flex items-center gap-3 animate-slide-up"
        :class="{
          'bg-emerald-500 text-white': toast.type === 'success',
          'bg-red-500 text-white': toast.type === 'error',
          'bg-blue-500 text-white': toast.type === 'info'
        }"
      >
        <CheckCircle v-if="toast.type === 'success'" class="w-5 h-5" />
        <AlertCircle v-else-if="toast.type === 'error'" class="w-5 h-5" />
        <AlertCircle v-else class="w-5 h-5" />
        <span class="font-medium">{{ toast.message }}</span>
      </div>
    </Transition>
  </div>
</template>
